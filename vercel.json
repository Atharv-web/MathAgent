{
    "builds": [
      {
        "src": "backend/main.py",
        "use": "@vercel/python"
      },
      {
        "src": "frontend/math-agent/package.json",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "build"
        }
      }
    ],
    "routes": [
      { "src": "/api/(.*)", "dest": "backend/main.py" },
      { "src": "/(.*)", "dest": "frontend/math-agent/$1" }
    ]
  }
  